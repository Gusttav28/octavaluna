{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "components/brand-story.jsx",
    "app/contact/page.jsx",
    "app/collections/page.jsx",
    "app/account/page.jsx",
    "app/account/loading.jsx",
    "app/about/page.jsx",
    "components/testimonials.jsx",
    "components/product-grid.jsx",
    "components/newsletter.jsx",
    "components/hero-section.jsx",
    "components/header.jsx",
    "components/footer.jsx",
    "components/featured-categories.jsx",
    "app/page.jsx",
    "app/layout.jsx"
, "app/shop/page.jsx"  ],
  "exclude": [
    "node_modules"
  ]
}